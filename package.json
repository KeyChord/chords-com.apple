{
  "name": "chords",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    "./*": "./dist/*"
  },
  "engines": {
    "pnpm": ">=9"
  },
  "scripts": {
    "build:src": "esbuild ./src/*.ts --bundle --outdir=dist --platform=node --target=node18 --format=esm --external:chord",
    "build": "pnpm run build:src"
  },
  "dependencies": {
    "desm": "^1.3.1",
    "get-port": "^7.2.0",
    "jquery-as-string": "^0.4.0",
    "jxa-run-compat": "^1.6.0",
    "nano-spawn-compat": "^2.0.6",
    "outdent": "^0.8.0",
    "run-jxa": "^4.0.0"
  },
  "devDependencies": {
    "@jxa/global-type": "^1.4.0",
    "bun-types": "^1.3.11",
    "chord-types": "^0.1.0",
    "esbuild": "^0.27.4",
    "llrt-types": "github:awslabs/llrt#path:/types",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.0"
}