{
  "name": "chords",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    "./*": "./dist/*"
  },
  "engines": {
    "pnpm": ">=9"
  },
  "scripts": {
    "build:typescript": "esbuild src/* --bundle --outdir=dist --platform=node --target=node18 --format=esm",
    "build": "pnpm run build:typescript"
  },
  "dependencies": {
    "jxa-run-compat": "^1.5.0",
    "nano-spawn-compat": "^2.0.6",
    "run-jxa": "^4.0.0"
  },
  "devDependencies": {
    "@jxa/global-type": "^1.4.0",
    "chord-types": "^0.1.0",
    "esbuild": "^0.27.4",
    "llrt-types": "github:awslabs/llrt#path:/types",
    "typescript": "^6.0.2"
  }
}
